{
  "name": "mvvm-web-project",
  "version": "1.0.0",
  "description": "Proyecto web fullstack con patrón MVVM por módulos para múltiples equipos",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:client\" \"npm run dev:server\"",
    "dev:client": "vite client",
    "dev:server": "node --watch server/index.js",
    "build": "vite build client",
    "preview": "vite preview",
    "lint": "eslint . --ext .js",
    "lint:fix": "eslint . --ext .js --fix",
    "test": "vitest",
    "test:ui": "vitest --ui"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.18.2"
  },
  "devDependencies": {
    "concurrently": "^8.2.0",
    "eslint": "^8.56.0",
    "vite": "^5.0.0",
    "vitest": "^1.0.0"
  }
}
